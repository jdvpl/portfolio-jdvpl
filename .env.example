# EmailJS — direct contact-form delivery (no mail client window).
# Create a free account at https://www.emailjs.com, add an email service and a
# template, then copy these IDs into a local ".env.local" file.
#
# Your template should reference these variables:
#   {{from_name}}  {{reply_to}}  {{message}}  {{to_email}}
#
# If these are left empty, the contact form gracefully falls back to mailto:.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
